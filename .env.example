# === OpenRouter (primary LLM) ===
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL_PLANNER=anthropic/claude-3.5-sonnet
OPENROUTER_MODEL_ANALYZER=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MODEL_REPORT=anthropic/claude-3.5-sonnet

# === Ollama (local LLM fallback for sensitive data) ===
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# === Database ===
DB_PATH=/app/data/openclaw.db

# Optional Supabase sync
SUPABASE_URL=
SUPABASE_KEY=

# === Agent config ===
MAX_AGENT_STEPS=20
TOOL_TIMEOUT_SECONDS=600
TOOL_OUTPUT_MAX_BYTES=2000000

# === UI ===
STREAMLIT_SERVER_PORT=8501

# === Hunter identity (for report signatures) ===
HUNTER_HANDLE=zwanski
HUNTER_EMAIL=mohamed@zwanski.org
